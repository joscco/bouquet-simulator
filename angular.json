{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "cache": {
      "enabled": false
    }
  },
  "projects": {
    "bouquet-simulator": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {"glob": "**/*", "input": "public"},
              {
                "glob": "material-symbols-outlined-latin-400-normal.woff2",
                "input": "node_modules/@fontsource/material-symbols-outlined/files",
                "output": "fonts"
              }
            ],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "production": {
              "outputHashing": "all",
              "budgets": [
                {"type": "initial", "maximumWarning": "800kB", "maximumError": "1.5MB"}
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {"buildTarget": "bouquet-simulator:build:production"},
            "development": {"buildTarget": "bouquet-simulator:build:development"}
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
